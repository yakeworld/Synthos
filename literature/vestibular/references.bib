@article{gajendiran2024acquisition,
  title = {Acquisition and Detection of Eye Movement Using Electrooculography},
  author = {Sruthilaya Gajendiran and Yuvaraj Sivagnanam},
  year = 2024,
  journal = {2024 International Conference on Signal Processing and Advance Research in Computing (SPARC)},
  volume = {1},
  pages = {1-5},
  abstract = {Human-Computer Interaction (HCI) systems are becoming admired daily for eye-tracking environments. Electrooculography (EOG) is the technique for recording eye movement with the help of keeping electrodes near the eyes and forehead. EOG is captured by recording polarization potential between the cornea and retina, which measures corneal-retinal potential (CPR). In this concept, eye movement generates electric signals so that we can able to control the device in his/her environment and communicate with the required people. EOG signals are taken as the primary input using Electrodes. In the electrode first ionic energy converts into an electric signal in the body which is amplified and preprocessed to remove noise and artifacts then feature is extracted and used for real-time applications like biomedical and rehabilitation engineering applications, home automation, multitask gadget control, etc. In this process time domain features are calculated such as Mean, STD, RMS, Skewness, and Kurtosis then saccade and fixation are detected in Blink signal. In the future, EOGs may provide attractive means for virtual reality and valuable communication tools.},
  doi = {10.1109/SPARC61891.2024.10829113},
  corpusid = {275438547},
  referenceCount = 21,
  citationCount = 2
}

@article{liu2024a,
  title = {A novel approach for the processing and classification of electrooculographic signals},
  author = {Xinrui Liu and Jianli Wang and Mingyan Wang and Yulin Gong},
  year = 2024,
  journal = {Proceedings of the 5th International Conference on Computer Information and Big Data Applications},
  abstract = {As technology continues to advance, the utilization of electrooculographic signals (EOG) in human-computer interaction and the biomedical field has progressively expanded. Notably, the processing and analysis of EOG signals are pivotal for achieving precise eye-tracking and visual control. Consequently, this paper introduces a methodology founded upon wavelet packet transformation and Generalized Learning Vector Quantization (GLVQ). This approach is tailored to the classification of saccadic and blink movements across four directions based on EOG signals. Initially, the method preprocesses EOG signals, employing endpoint detection techniques to extract pertinent segments associated with saccadic and blink movements. Subsequently, wavelet packet transformation is harnessed to analyze non-stationary and nonlinear characteristics, constructing a feature matrix used for classification through GLVQ. Experimental outcomes underscore the method's exemplary performance in addressing complex EOG signal classification tasks, achieving an accuracy rate exceeding 90%. In comparison to conventional approaches, the combination of wavelet packet transformation and GLVQ exhibits superior adaptive learning and classification capabilities, enabling enhanced adaptability to signal variations and complexities.},
  doi = {10.1145/3671151.3671326},
  corpusid = {271420397},
  referenceCount = 13,
  citationCount = 0
}

