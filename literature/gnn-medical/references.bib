@article{manuel2026an,
  title = {An Adaptive Reinforcement Learning-Based Heap Optimization Framework for Robust Medical Image Diagnosis and Prediction (ARL-HBO)},
  author = {Alvin Manuel and Dr.V.Vignaraj Ananth and Dr. G. Gunasekaran and Doug Dean},
  year = 2026,
  journal = {2026 3rd International Conference on Research Methodologies in Knowledge Management, Artificial Intelligence and Telecommunication Engineering (RMKMATE)},
  pages = {1-8},
  abstract = {The recent advances in deep neural networks have quickly accelerated the application of deep learning in the diagnosis of medical images and decision support systems. Nevertheless, aside from the architecture of the network, the performance of these networks is significantly dependent on the choice of hyperparameters. Inadequate hyperparameter configurations often lead to suboptimal convergence and reduced diagnostic reliability. To address this challenge, this paper proposes an Adaptive Reinforcement Learning-Based Heap Optimization (ARL-HBO) framework for robust medical image diagnosis and prediction. The proposed framework integrates reinforcement learning with an improved Heap-based Optimization algorithm, which is enriched with grey wolf optimization concepts and orthogonal learning approaches. The ARL-HBO strategy optimizes the hyperparameters of a deep residual neural network, which leads to enhanced classification accuracy, stability, and generalization. The experimental outcome reveals that the proposed strategy performs better than other strategies.},
  doi = {10.1109/RMKMATE69073.2026.11518806},
  corpusid = {288470407},
  referenceCount = 14,
  citationCount = 0
}

@article{song2026freqconvmamba,
  title = {FreqConvMamba: Frequency-guided hierarchical hybrid SSM-CNN for medical image segmentation.},
  author = {Yantao Song and Weixiang Dou and Yuhua Qian and Jieru Jia and Zheqing Zhu},
  year = 2026,
  journal = {Medical image analysis},
  volume = {111},
  pages = {104019},
  abstract = {Accurate segmentation of medical images is a fundamental prerequisite for quantitative disease diagnosis, treatment planning, and computational pathology. Although convolutional neural networks (CNNs) and Mamba-based approaches have shown promise in this domain, each comes with distinct strengths and limitations. To address these challenges, we propose a novel hierarchical network named FreqConvMamba. The core innovation of this architecture lies in its frequency-guided feature extraction mechanism, which enables simultaneous modeling of both local and global information across spatial and frequency domains. Furthermore, the integration of Haar wavelet transformation decomposes features into different frequency components, thereby enhancing the representation of fine details such as anatomical boundaries. We also introduce a Frequency Position Encoding (FPE) module that incorporates positional encoding along the frequency dimension, embedding spatial structural awareness while preserving the discriminative nature of frequency representations. This design effectively mitigates the lack of spatial perception in frequency-domain features and significantly improves the efficiency of frequency-aware feature extraction. Experimental evaluations on five public datasets spanning three imaging modalities demonstrate that FreqConvMamba outperforms state-of-the-art methods across multiple performance metrics. Code is available at: https://github.com/ccode-Rookie/FreqConvMamba.},
  doi = {10.1016/j.media.2026.104019},
  corpusid = {286404217},
  pubmed = {41855719},
  referenceCount = 39,
  citationCount = 1,
  issn = {1361-8415},
  publisher = {Medical Image Analysis}
}

@article{wang2026adhd,
  title = {ADHD Classification With GCN via Joint Feature Learning Among Nodes and Edges},
  author = {Xiaotong Wang and Yibin Tang and Yuan Gao and Xiaojing Meng and Ying Chen and Aimin Jiang},
  year = 2026,
  journal = {IEEE Transactions on Medical Imaging},
  volume = {45},
  pages = {2481-2492},
  abstract = {Brain functional connectivity networks (FCNs) derived from resting-state functional magnetic resonance imaging (rs-fMRI) data have been widely used to identify altered brain network patterns in attention-deficit/hyperactivity disorder (ADHD). Current graph neural network (GNN) approaches using FCNs predominantly emphasize node features while underutilizing edge information. Moreover, these GNN-based methods also inadequately represent dynamic interdependencies among evolving node features across network layers, limiting their diagnostic performance. We present a graph convolutional network via joint feature learning between nodes and edges (JNEL-GCN) that integrates neuroimaging features for ADHD classification and biomarker discovery. Our framework constructs dual graph representations: 1) a node graph using amplitude of low-frequency fluctuations (ALFF) measures across multiple frequency bands as nodal features, along with functional connectivity (FC) and node feature relationship matrices as edge attributes; and 2) an edge graph derived through line graph theory, enabling the interchange of node and edge roles. By leveraging the dual-graph design, our model implements an alternating feature update mechanism with optimized graph convolution operations, facilitating feature hierarchical learning of node-edge relationships across network layers. Extensive experiments demonstrate remarkable performance, achieving 97.3% accuracy on ADHD200 and 97.1% on ABIDE-I datasets, significantly outperforming current benchmarks. Meanwhile, gradient-based biomarker analysis identifies significant regions in bilateral limbic and default mode networks associated with ADHD, aligning with the findings in existing literature. Therefore, this dual-graph approach advances neuroimaging-based diagnosis by comprehensively capturing dynamic network interactions, while providing interpretable biomarkers for clinical neuroscience applications.},
  doi = {10.1109/TMI.2026.3656430},
  corpusid = {284913474},
  pubmed = {41557570},
  referenceCount = 51,
  citationCount = 1,
  issn = {0278-0062},
  publisher = {IEEE Transactions on Medical Imaging}
}

@article{susmitha2026explainable,
  title = {Explainable Mobilenetv2 Framework with Knowledge Graphs for Classifying Hand-Foot-Mouth and Chickenpox Diseases},
  author = {N. Susmitha and T. Anuradha},
  year = 2026,
  journal = {2026 Sixth International Conference on Advances in Electrical, Computing, Communications and Sustainable Technologies (ICAECT)},
  pages = {1-6},
  abstract = {Hand-Foot-and-Mouth Disease (HFMD) and Chickenpox are clinically significant viral infections that manifest with overlapping dermatological presentations, often complicating accurate differential diagnosis. Timely and precise identification is crucial for effective therapeutic management and outbreak prevention. Leveraging advances in deep learning, this study investigates the efficacy of MobileNetV2, a lightweight yet high-performing convolutional neural network, for binary classification of HFMD and Chickenpox using high-resolution skin lesion images. The finetuned model achieved 98 % training accuracy and 97 % test accuracy, demonstrating strong generalization across unseen data. To foster transparency and enhance clinical trust, Gradient-weighted Class Activation Mapping (Grad-CAM) was employed to highlight discriminative lesion regions guiding the classification process, while knowledge graph integration provided semantic contextualization of predictions, bridging the gap between raw outputs and clinical interpretability. The experimental findings underscore the potential of MobileNetV2 as a computationally efficient and interpretable diagnostic tool, advancing the paradigm of AI-driven medical image analysis in dermatology.},
  doi = {10.1109/ICAECT68478.2026.11426137},
  corpusid = {286505922},
  referenceCount = 21,
  citationCount = 0
}

@article{amendola2024from,
  title = {From Voxels to Insights: Exploring the Effectiveness and Transparency of Graph Neural Networks in Brain Tumor Segmentation},
  author = {D. Amendola and T. Basile and Giovanna Castellano and G. Vessio and G. Zaza},
  year = 2024,
  journal = {2024 International Joint Conference on Neural Networks (IJCNN)},
  pages = {1-7},
  abstract = {Accurate brain tumor segmentation is crucial for precise medical diagnosis and treatment planning in medical imaging. This research delves into assessing the effectiveness and transparency of Graph Neural Networks (GNNs) in brain tumor segmentation. The primary objectives include comparing various GNN architectures and improving their understandability by applying the GNNExplainer method. Leveraging the BraTS 2021 challenge dataset, which consists of MRI scans and corresponding ground truth annotations, the study reveals the successful application of GNNs in achieving precise brain tumor segmentation. By incorporating GNNExplainer, the explainability of the models is significantly enhanced, shedding light on the decision-making processes within the network. The proposed approach could advance the field of brain tumor segmentation, providing clinicians with accurate and transparent models to inform their decision-making processes in patient care.1},
  doi = {10.1109/IJCNN60899.2024.10650146},
  dblp = {conf/ijcnn/AmendolaBCVZ24},
  corpusid = {272587255},
  referenceCount = 36,
  citationCount = 4,
  publisher = {IEEE International Joint Conference on Neural Network}
}

@article{shen2025complex,
  title = {Complex Pattern Recognition and Clinical Application of Artificial Intelligence in Medical Imaging Diagnosis},
  author = {Danyating Shen},
  year = 2025,
  journal = {2025 International Conference on Intelligent Communication Networks and Computational Techniques (ICICNCT)},
  pages = {1-8},
  abstract = {Medical imaging not only plays an important role in revealing tissue and pathological information in clinical diagnosis and treatment, but also always plays a core role in the early identification of diseases and the formulation of treatment decisions. However, with the continuous growth of the scale and complexity of imaging data, the manual film reading method is difficult to ensure the efficiency and consistency of diagnosis due to its time-consuming nature and the subjective differences of the readers. Therefore, this study proposes a multimodal fusion intelligent analysis framework. In the visual modeling stage, this framework extracts fine-grained features through deep neural networks and enhances the aggregation ability of the lesion area by using the attention mechanism. In the semantic reasoning stage, it improves the model's capture effect on potential pathological logical relationships by introducing medical knowledge and context modeling. In the diagnostic report generation stage, the generator with sequence modeling advantages is combined with cross-modal consistency constraints and contrast training strategies to ensure a close fit between text expression and visual features. The experimental results on the IU X-Ray and MIMIC-CXR datasets show that this method outperforms mainstream systems in multiple text generation evaluation metrics. Moreover, the ablation experiment further demonstrated the necessity of each module in the overall performance improvement. This indicates that this framework can not only achieve precise analysis of complex medical image structures but also generate diagnostic texts with clinical explanatory value. This thus provides a feasible solution for the application of artificial intelligence in the automatic interpretation of medical images and clinical auxiliary decisionmaking, and demonstrates broad development potential.},
  doi = {10.1109/ICICNCT66124.2025.11232821},
  corpusid = {283098046},
  referenceCount = 13,
  citationCount = 1
}

@article{jiang2023vigunet,
  title = {ViG-UNet: Vision Graph Neural Networks for Medical Image Segmentation},
  author = {Juntao Jiang and Xiyu Chen and Guanzhong Tian and Y. Liu},
  year = 2023,
  journal = {2023 IEEE 20th International Symposium on Biomedical Imaging (ISBI)},
  pages = {1-5},
  abstract = {Deep neural networks have been widely used in medical image analysis and medical image segmentation is one of the most important tasks. U-shaped neural networks with encoder-decoder are prevailing and have succeeded greatly in various segmentation tasks. While CNNs treat an image as a grid of pixels in Euclidean space and Transformers recognize an image as a sequence of patches, graph-based representation is more generalized and can construct connections for each part of an image. In this paper, we propose a novel ViG-UNet, a graph neural network-based U-shaped architecture with the encoder, the decoder, the bottleneck, and skip connections. The downsampling and upsampling modules are also carefully designed. The experimental results on ISIC 2016, ISIC 2017 and Kvasir-SEG datasets demonstrate that our proposed architecture outperforms most existing classic and state-of-the-art U-shaped networks.},
  doi = {10.1109/ISBI53787.2023.10230496},
  dblp = {journals/corr/abs-2306-04905},
  openAccessPdf = {https://arxiv.org/pdf/2306.04905},
  corpusid = {259108750},
  referenceCount = 24,
  citationCount = 27,
  issn = {1945-7928},
  publisher = {IEEE International Symposium on Biomedical Imaging}
}

@article{saeidi2024leveraging,
  title = {Leveraging Medical Foundation Model Features in Graph Neural Network‐Based Retrieval of Breast Histopathology Images},
  author = {Nematollah Saeidi and Hossein Karshenas and B. Shoushtarian and Sepideh Hatamikia and R. Woitek and A. Mahbod},
  year = 2024,
  journal = {International Journal of Imaging Systems and Technology},
  abstract = {Breast cancer is the most common cancer type in women worldwide. Early detection and appropriate treatment can significantly reduce its impact. While histopathology examinations play a vital role in rapid and accurate diagnosis, they often require experienced medical experts for proper recognition and cancer grading. Automated image retrieval systems have the potential to assist pathologists in identifying cancerous tissues, thereby accelerating the diagnostic process. Nevertheless, proposing an accurate image retrieval model is challenging due to considerable variability among the tissue and cell patterns in histological images. In this work, we leverage the features from foundation models in a novel attention‐based adversarially regularized variational graph autoencoder model for breast histological image retrieval. Our results confirm the superior performance of models trained with foundation model features compared to those using pre‐trained convolutional neural networks (up to 7.7% and 15.5% for mAP and mMV, respectively), with the pre‐trained general‐purpose self‐supervised model for computational pathology (UNI) delivering the best overall performance. Evaluated on two publicly available histology image datasets of breast cancer, our top‐performing model, trained with UNI features, achieved average mAP/mMV scores of 96.7%/91.5% and 97.6%/94.2% for the BreakHis and BACH datasets, respectively. Our proposed retrieval model has the potential to be used in clinical settings to enhance diagnostic performance and ultimately benefit patients.},
  doi = {10.1002/ima.70346},
  corpusid = {269614216},
  referenceCount = 68,
  citationCount = 5
}

