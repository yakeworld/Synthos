# Synthos .gitignore — 严格过滤

# ============================================
# 1. 运行产出（每轮重新生成，不入库）
# ============================================
/outputs/
/evolution-state.json
/evolution-log.md
/evolution-report.json
/evolution-config.yaml
/update_state.py
github_projects_search.json

# ============================================
# 2. 归档（v3.x 遗留，不入库）
# ============================================
/archive/

# ============================================
# 3. API 密钥 / 环境变量
# ============================================
.env
*.env.local
*.env.*
api_keys.txt
secrets*

# ============================================
# 4. 大二进制文件（PDF/视频/音频/文档）
# ============================================
*.pdf
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.ts
*.aac
*.mp3
*.m4a
*.wav
*.flac
*.docx
*.pptx
!docs/Synthos_Full_Demo.pptx

# ============================================
# 5. 操作系统文件
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# 6. Python（主项目零Python，archive保留参考）
# ============================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ============================================
# 7. IDE / 编辑器
# ============================================
.idea/
.vscode/
*.code-workspace

# ============================================
# 8. 临时文件
# ============================================
.tmp/
temp/
*.tmp
*.log
*.bak
cache/
