# Synthos .gitignore — 严格过滤（2026-05-28 整理后版）

# ============================================
# 1. 论文稿件（不入库）
# ============================================
/outputs/

# ============================================
# 2. 进化引擎运行时（不入库）
# ============================================
/.evolution/

# ============================================
# 3. API 密钥 / 环境变量
# ============================================
.env
*.env.local
*.env.*
api_keys.txt
secrets*

# ============================================
# 4. 通用敏感文件模式
# ============================================
*.key
*.pem
*.crt
credentials*
auth.json
token*
**/.api_key

# ============================================
# 5. 大二进制文件
# ============================================
*.pdf
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.ts
*.aac
*.mp3
*.m4a
*.wav
*.flac
*.docx
*.pptx

# ============================================
# 6. 操作系统文件
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# 7. Python
# ============================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ============================================
# 8. IDE / 编辑器
# ============================================
.idea/
.vscode/
*.code-workspace

# ============================================
# 9. LaTeX 构建产物
# ============================================
*.aux
*.bbl
*.blg
*.out
*.spl
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot

# ============================================
# 10. 临时文件
# ============================================
.tmp/
temp/
*.tmp
*.log
*.bak
cache/

# ============================================
# 11. 🔴 敏感信息 — 禁止上传（已泄露需改密码）
# ============================================
tools/.domain_cache/
tools/paper-manager/.domain_cache/
tools/paper-manager/*.log
tools/paper-manager/.api_key
tools/paper-manager/.env
tools/paper-manager/auto_fix_d8.py
tools/paper-manager/batch_enhance_all.py
tools/paper-manager/batch_meddata_all.py

# ============================================
# 12. GitHub 非核心
# ============================================
.github/

# ============================================
# 13. 已淘汰的根目录条目（历史引用，安全保留）
# ============================================
/update_state.py
github_projects_search.json
pipeline-trace.json
/竞赛材料/
skills/notebooklm-sources-sync.py
skills/upload-pdfs.sh
skills/upload-pdfs-v2.sh
skills/notebooklm-bibtex-workflow.md
skills/pdf-download-racing.md
skills/references/racing-engine-code.py
skills/references/scihub-racing-code.py
skills/skill_network.json
skills/skill_registry.json
skills/skill_tree.json
skills/SKILL_TREE.md
docs/promotion/
