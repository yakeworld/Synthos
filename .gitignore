# Synthos .gitignore — 严格过滤

# ============================================
# 1. 论文稿件（不入库）
# ============================================
/submission/

# ============================================
# 2. 运行产出（每轮重新生成，不入库）
# ============================================
/outputs/
/evolution-state.json
/evolution-log.md
/evolution-report.json
/evolution-config.yaml
/update_state.py
github_projects_search.json
pipeline-trace.json

# ============================================
# 3. 归档（v3.x 遗留，不入库）
# ============================================
/archive/
/竞赛材料/

# ============================================
# 4. API 密钥 / 环境变量
# ============================================
.env
*.env.local
*.env.*
api_keys.txt
secrets*

# ============================================
# 5. 个人知识图谱（不入库）
# ============================================
/knowledge-graph/

# ============================================
# 6. 大二进制文件
# ============================================
*.pdf
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.ts
*.aac
*.mp3
*.m4a
*.wav
*.flac
*.docx
*.pptx

# ============================================
# 7. 操作系统文件
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# 8. Python（主项目零Python，archive保留参考）
# ============================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ============================================
# 9. IDE / 编辑器
# ============================================
.idea/
.vscode/
*.code-workspace

# ============================================
# 10. LaTeX 构建产物
# ============================================
*.aux
*.bbl
*.blg
*.out
*.spl
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc
*.lof
*.lot

# ============================================
# 11. 临时文件
# ============================================
.tmp/
temp/
*.tmp
*.log
*.bak
cache/
