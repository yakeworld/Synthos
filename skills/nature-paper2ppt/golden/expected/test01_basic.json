{
  "test_case": "nature-paper2ppt-basic",
  "verification_criteria": [
    {"check": "presentation_created", "condition": "output/final_presentation_cn.pptx exists", "weight": "critical"},
    {"check": "qa_report_created", "condition": "output/qa_report.md exists", "weight": "high"},
    {"check": "slide_count", "condition": "12 <= slide_count <= 16", "weight": "high"},
    {"check": "chinese_content", "condition": "slide titles are in Chinese", "weight": "high"},
    {"check": "cover_slide", "condition": "has paper title, authors, journal, year", "weight": "high"},
    {"check": "conclusion_slide", "condition": "has summary/future directions", "weight": "medium"},
    {"check": "speaker_notes", "condition": "at least 50% slides have speaker notes", "weight": "medium"},
    {"check": "source_labels", "condition": "figure slides include source labels", "weight": "medium"},
    {"check": "evidence_map_logic", "condition": "uses evidence-map presentation logic", "weight": "low"},
    {"check": "no_fabrication", "condition": "no invented results or exaggerated claims", "weight": "critical"},
    {"check": "no_decorative_assets", "condition": "no stock images or decorative gradients", "weight": "low"}
  ],
  "minimum_pass_score": 0.80
}
